EDGEOPS_API_HOST=127.0.0.1
EDGEOPS_API_PORT=8787
EDGEOPS_API_PREFIX=/api
EDGEOPS_DB_CLIENT=sqlite
EDGEOPS_DB_PATH=./data/edgeops-cache.sqlite
EDGEOPS_SECRET=replace-with-a-long-random-secret
EDGEOPS_FORTIGATE_TIMEOUT_MS=15000
EDGEOPS_DEFAULT_ADMIN_USERNAME=admin
EDGEOPS_DEFAULT_ADMIN_PASSWORD=edgeops-admin
EDGEOPS_SESSION_TTL_HOURS=12
# Optional: set a specific browser origin only when the frontend is hosted separately from the API.
# EDGEOPS_CORS_ORIGIN=https://edgeops.example.com
# Optional: force Secure on session cookies. Auto-enabled when the request arrives over HTTPS.
# EDGEOPS_COOKIE_SECURE=true
EDGEOPS_FRONTEND_PORT=8080
EDGEOPS_FRONTEND_HOST=0.0.0.0
EDGEOPS_DEV_FRONTEND_PORT=5173
EDGEOPS_DEV_FRONTEND_HOST=0.0.0.0
# Optional: point the production frontend proxy at a different API origin.
# EDGEOPS_API_ORIGIN=http://127.0.0.1:8787
# Optional: use MySQL instead of SQLite by setting EDGEOPS_DB_CLIENT=mysql.
# EDGEOPS_MYSQL_HOST=127.0.0.1
# EDGEOPS_MYSQL_PORT=3306
# EDGEOPS_MYSQL_USER=edgeops
# EDGEOPS_MYSQL_PASSWORD=
# EDGEOPS_MYSQL_DATABASE=edgeops
# EDGEOPS_MYSQL_SSL=false
# EDGEOPS_MYSQL_CONNECTION_LIMIT=10
# Optional: use a single MySQL connection URI instead of the host/user fields.
# EDGEOPS_MYSQL_URI=mysql://edgeops:password@127.0.0.1:3306/edgeops
# Optional: set this only if you change EDGEOPS_API_PREFIX and rebuild the frontend.
# VITE_API_PREFIX=/api
# Optional: set to 1 if start.sh should skip rebuilding dist/.
# EDGEOPS_SKIP_BUILD=0
