EDGEOPS_PORT=8787
EDGEOPS_DB_PATH=./data/edgeops-cache.sqlite
EDGEOPS_SECRET=replace-with-a-long-random-secret
EDGEOPS_DEFAULT_ADMIN_USERNAME=admin
EDGEOPS_DEFAULT_ADMIN_PASSWORD=edgeops-admin
EDGEOPS_SESSION_TTL_HOURS=12
EDGEOPS_FRONTEND_PORT=8080
EDGEOPS_FRONTEND_HOST=0.0.0.0
EDGEOPS_DEV_FRONTEND_PORT=5173
EDGEOPS_DEV_FRONTEND_HOST=0.0.0.0
# Optional: point the production frontend proxy at a different API origin.
# EDGEOPS_API_ORIGIN=http://127.0.0.1:8787
# Optional: set to 1 if start.sh should skip rebuilding dist/.
# EDGEOPS_SKIP_BUILD=0
